{
  "name": "prism",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "examples/prism-mcp-adapter"
  ],
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0 --port 3732",
    "build": "next build",
    "test": "vitest run",
    "db:up": "docker compose --env-file .env.local up -d postgres",
    "db:down": "docker compose --env-file .env.local down",
    "db:migrate": "node scripts/ensure-local-encryption-key.mjs && node scripts/run-migrations.mjs"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "next": "^16.0.3",
    "pg": "^8.16.3",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "server-only": "^0.0.1",
    "shadcn": "^4.8.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0"
  },
  "overrides": {
    "postcss": "^8.5.15"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/pg": "^8.15.6",
    "@types/react": "^19.2.6",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  }
}
