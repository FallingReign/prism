# Database substrate for local development. Docker Compose and the Prism
# hosted service both read these values so local credentials do not drift.
POSTGRES_USER=prism
POSTGRES_PASSWORD=prism_local_password
POSTGRES_DB=prism
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Optional deployment override. Leave unset for local development so the
# Postgres fields above remain the canonical source.
# DATABASE_URL=postgres://prism:prism_local_password@localhost:5432/prism

# Non-secret public URL placeholders for future Slack OAuth configuration.
# For same-machine local development, use localhost. For the pilot host VM,
# use http://10.62.240.10:3732 and the matching callback URL instead.
PRISM_PUBLIC_BASE_URL=http://localhost:3732
SLACK_OAUTH_REDIRECT_URI=http://localhost:3732/v1/slack/oauth/callback

# Future Slack credentials, held only by the Prism hosted service.
SLACK_CLIENT_ID=replace-with-slack-client-id
SLACK_CLIENT_SECRET=replace-with-slack-client-secret
SLACK_SIGNING_SECRET=replace-with-slack-signing-secret
SLACK_BOT_SCOPES=channels:read,channels:history,groups:read,groups:history,im:read,im:history,mpim:read,mpim:history,chat:write,reactions:read,reactions:write,files:read,users:read
SLACK_USER_SCOPES=channels:read,channels:history,groups:read,groups:history,im:read,im:history,mpim:read,mpim:history,chat:write,reactions:read,reactions:write,search:read,files:read,users:read

# Server-side Slack credential envelope encryption for local development.
# `npm run db:migrate` fills these in for ignored .env.local if they are absent
# or still placeholders. Use managed secret/KMS-backed values outside local dev.
PRISM_CREDENTIAL_ENCRYPTION_KEY=replace-with-base64-32-byte-key
PRISM_CREDENTIAL_ENCRYPTION_KEY_ID=replace-with-key-id

# Non-production only: lets callback tests/manual QA exercise the real Prism
# persistence/encryption path with synthetic Slack token canaries.
PRISM_SLACK_OAUTH_MOCK=0

# Non-production only: use Prism's synthetic Slack Web API upstream for local
# mock QA. Leave off/0 for real Slack Web API forwarding after OAuth linking.
PRISM_SLACK_WEB_API_MOCK=0

# Future Prism developer token secret material. Do not use Slack tokens here.
PRISM_DEVELOPER_TOKEN_PEPPER=replace-with-random-local-pepper
PRISM_DEVELOPER_TOKEN_PEPPER_ID=replace-with-pepper-id
PRISM_DEVELOPER_TOKEN=replace-with-developer-token

