# Database substrate for local development.
DATABASE_URL=postgres://prism:prism_local_password@localhost:5432/prism

# Non-secret public URL placeholders for future Slack OAuth configuration.
PRISM_PUBLIC_BASE_URL=http://localhost:3000
SLACK_OAUTH_REDIRECT_URI=http://localhost:3000/v1/slack/oauth/callback

# Future Slack credentials, held only by the Prism hosted service.
SLACK_CLIENT_ID=replace-with-slack-client-id
SLACK_CLIENT_SECRET=replace-with-slack-client-secret
SLACK_SIGNING_SECRET=replace-with-slack-signing-secret

# Future Prism developer token secret material. Do not use Slack tokens here.
PRISM_DEVELOPER_TOKEN_PEPPER=replace-with-random-local-pepper
